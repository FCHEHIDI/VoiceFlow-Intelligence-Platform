{
  "annotations": {"list": []},
  "editable": true,
  "graphTooltip": 1,
  "id": null,
  "title": "VoiceFlow — Diarization",
  "uid": "voiceflow-diarization",
  "schemaVersion": 38,
  "version": 1,
  "time": {"from": "now-24h", "to": "now"},
  "refresh": "5m",
  "tags": ["voiceflow", "diarization"],
  "panels": [
    {
      "id": 1,
      "title": "DER trend (%)",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 9, "w": 12, "x": 0, "y": 0},
      "targets": [
        {
          "expr": "avg_over_time(diarization_error_rate[1h]) * 100",
          "legendFormat": "DER %",
          "refId": "A"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "percent"}}
    },
    {
      "id": 2,
      "title": "Segments per minute",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 9, "w": 12, "x": 12, "y": 0},
      "targets": [
        {"expr": "sum(rate(diarization_segments_total[1m]))", "refId": "A"}
      ]
    },
    {
      "id": 3,
      "title": "Speakers detected (gauge)",
      "type": "gauge",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 6, "w": 8, "x": 0, "y": 9},
      "targets": [
        {"expr": "max(diarization_speakers_active)", "refId": "A"}
      ]
    },
    {
      "id": 4,
      "title": "Embedding extraction P99 (ms)",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 6, "w": 16, "x": 8, "y": 9},
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(inference_latency_seconds_bucket[5m]))) * 1000",
          "legendFormat": "P99 (ms)",
          "refId": "A"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "ms"}}
    }
  ]
}
