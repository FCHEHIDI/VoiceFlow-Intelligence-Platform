{
  "annotations": {
    "list": []
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "title": "VoiceFlow — Overview",
  "uid": "voiceflow-overview",
  "schemaVersion": 38,
  "version": 1,
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "refresh": "30s",
  "tags": ["voiceflow"],
  "panels": [
    {
      "id": 1,
      "title": "Inference latency P99 (ms)",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(inference_latency_seconds_bucket[5m]))) * 1000",
          "legendFormat": "P99 (ms)",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.50, sum by (le) (rate(inference_latency_seconds_bucket[5m]))) * 1000",
          "legendFormat": "P50 (ms)",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {"unit": "ms"}
      }
    },
    {
      "id": 2,
      "title": "Inference requests / second",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "targets": [
        {
          "expr": "sum(rate(inference_requests_total[1m]))",
          "legendFormat": "req/s",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "Active WebSocket connections",
      "type": "stat",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 6, "w": 6, "x": 0, "y": 8},
      "targets": [
        {"expr": "sum(websocket_connections_active)", "refId": "A"}
      ]
    },
    {
      "id": 4,
      "title": "Inference error rate (%)",
      "type": "stat",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 6, "w": 6, "x": 6, "y": 8},
      "targets": [
        {
          "expr": "sum(rate(inference_errors_total[5m])) / clamp_min(sum(rate(inference_requests_total[5m])), 1) * 100",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {"mode": "absolute", "steps": [
            {"color": "green", "value": 0},
            {"color": "yellow", "value": 1},
            {"color": "red", "value": 5}
          ]}
        }
      }
    },
    {
      "id": 5,
      "title": "ECS RunningTaskCount",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 6, "w": 12, "x": 12, "y": 8},
      "targets": [
        {
          "expr": "ecs_running_task_count{cluster=~\"voiceflow.*\"}",
          "legendFormat": "{{ service_name }}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 6,
      "title": "Model load duration (s)",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 6, "w": 12, "x": 0, "y": 14},
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(model_load_seconds_bucket[15m]))",
          "legendFormat": "P95",
          "refId": "A"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "s"}}
    }
  ]
}
