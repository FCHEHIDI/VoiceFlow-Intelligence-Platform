# VoiceFlow Intelligence Platform — environment template
# Copy: cp .env.example .env  |  Do not commit .env
#
# 32+ char secret for signing:
#   openssl rand -hex 32

ENV=development
JWT_SECRET_KEY=replace_with_openssl_rand_hex_32_at_least_32_chars_long_value_here
POSTGRES_USER=voiceflow
POSTGRES_PASSWORD=replace_with_strong_postgres_password
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=voiceflow
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
CORS_ORIGINS=http://localhost:3000,http://localhost:8000
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=replace_with_strong_grafana_password

# AWS (connect only in production; optional for local)
AWS_REGION=eu-west-1
# JWT_SECRET_ARN=arn:aws:secretsmanager:region:123456789012:secret:...
# DB_SECRET_ARN=arn:aws:secretsmanager:region:123456789012:secret:...
